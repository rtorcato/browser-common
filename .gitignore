# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
logs/
*.log
*.log.*

# Environment variables
.env
.env.*

# Build output
dist/
build/
out/
tsconfig*.tsbuildinfo

# System files
.DS_Store
Thumbs.db

# IDE files
# Share .vscode/settings.json + extensions.json (workspace conventions for any
# contributor) but ignore personal stuff (launch.json, debug history, etc.).
# The first negation overrides ~/.gitignore_global's blanket .vscode/ rule
# so git will descend into the directory and apply the per-file rules below.
!.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp

# Claude Code local settings (personal, not shared)
.claude/settings.local.json
.claude/worktrees/
