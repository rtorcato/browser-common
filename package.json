{
  "name": "@rtorcato/browser-common",
  "version": "1.0.0",
  "description": "Browser common code",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/browser-common.git"
  },
  "homepage": "https://github.com/rtorcato/browser-common#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/browser-common/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "keywords": [
    "browser-api",
    "web-api",
    "web-platform",
    "typescript",
    "esm",
    "tree-shakeable",
    "clipboard",
    "geolocation",
    "service-worker",
    "intersection-observer",
    "mutation-observer",
    "resize-observer",
    "fullscreen",
    "notifications",
    "websockets",
    "dom"
  ],
  "author": "Richard Torcato",
  "sideEffects": false,
  "scripts": {
    "build-dev": "rimraf ./dist && cross-env NODE_ENV=development node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "build-prod": "rimraf ./dist && cross-env NODE_ENV=production node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "==================== Common ====================": "",
    "lint": "pnpm exec biome lint .",
    "format": "pnpm exec biome format .",
    "check:fix": "pnpm exec biome check --fix",
    "check": "pnpm exec biome check .",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "knip": "knip",
    "================================================": ""
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "README.md"
  ],
